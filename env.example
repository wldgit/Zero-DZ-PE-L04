# Пример настроек для локального агента (Ollama).
# Скопируйте в .env и при необходимости измените значения.
# Приложение загружает .env через python-dotenv (если файл есть).

# Модель Ollama (должна быть установлена: ollama pull <модель>)
#OLLAMA_MODEL=llama3.1
OLLAMA_MODEL=qwen3.5:4b 

# Температура генерации: 0 — детерминированно, 0.3–0.7 — разнообразнее
OLLAMA_TEMPERATURE=0
